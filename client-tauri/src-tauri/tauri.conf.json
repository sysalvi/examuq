{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ExamUQ Client Tauri",
  "version": "0.1.0",
  "identifier": "id.uqd.examuq.clienttauri",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ExamUQ Client",
        "width": 620,
        "height": 640,
        "resizable": false,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "app",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ1MkRFNDk4MTFGODhGRDcKUldUWGovZ1JtT1F0UlNjcFV0UURnYnZpUnNwTU5PdnUvbllCeGdmSGY2UVNVVFZnalJNdlNia1AK",
      "endpoints": [
        "https://updates.examuq.id/{{target}}/{{arch}}/{{current_version}}?channel=stable"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
