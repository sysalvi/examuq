{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ExamUQ Client",
  "version": "0.1.6",
  "identifier": "id.uqd.examuq.clienttauri",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ExamUQ Client",
        "width": 460,
        "height": 600,
        "resizable": false,
        "minimizable": false,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "app",
      "nsis"
    ],
    "macOS": {
      "files": {
        "SharedSupport/README_MACOS.txt": "bundle/macos/README_MACOS.txt",
        "SharedSupport/FIX_MACOS.command": "bundle/macos/FIX_MACOS.command"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhFRjI3OUVDNEU3RkE2NkQKUldSdHBuOU83SG55anJQK2NEYnpvOUlhNUhzWCtKdE44UWs2SS9wRXZ0Q0dBSWFFQk1ReXMxancK",
      "endpoints": [
        "https://updates.examuq.id/{{target}}/{{arch}}/{{current_version}}?channel=stable"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
