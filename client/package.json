{
  "name": "examuq-client",
  "version": "0.1.0",
  "description": "ExamUQ desktop launcher for student exam flow",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "lint": "node --check main.js && node --check preload.js && node --check renderer/app.js",
    "dist": "electron-builder --publish never"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "id.uqd.examuq.client",
    "productName": "ExamUQ Client",
    "compression": "maximum",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json"
    ],
    "asar": true,
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "mac": {
      "target": [
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "zip"
      ]
    }
  }
}
